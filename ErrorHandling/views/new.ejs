<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>New Chat</title>
</head>
<body>
    <h2>Create new chat</h2>
    <form method="post" action="/chats">
        <input type="text" placeholder="Sender's name" name="from"><br><br>
        <textarea name="msg" placeholder="Write your message here"></textarea><br><br>
        <input type="text" placeholder="Receiver's name" name="to"><br><br>
        <button>Send</button>
    </form>
</body>
</html>