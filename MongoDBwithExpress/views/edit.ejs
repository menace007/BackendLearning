<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit</title>
</head>
<body>
    <h2>Edit your message</h2>
    <p>ID: <b><%= chat.id %></b></p>
    <p>From: <b><i><%= chat.from %></i></b></p>
    <p>To: <b><i><%= chat.to %></i></b></p>
    <form method="post" action="/chats/<%= chat._id %>?_method=put">
        <textarea name="msg" rows="5" cols="30"><%= chat.msg %></textarea><br>
        <button>Edit</button>
    </form>
</body>
</html>